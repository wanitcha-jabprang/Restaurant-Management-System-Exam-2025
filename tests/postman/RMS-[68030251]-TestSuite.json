				{
					"name": "SQL Injection in Search",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/menu?search=%27+OR+%271%27%3D%271",
							"host": ["{{base_url}}"],
							"path": ["menu"],
							"query": [
								{
									"key": "search",
									"value": "' OR '1'='1"
								}
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('TC-010: SQL Injection should NOT leak all records', () => {",
									"  const body = pm.response.json();",
									"  if (Array.isArray(body)) {",
									"    pm.expect(body.length, 'SQL Injection leaked ' + body.length + ' records').to.equal(0);",
									"  } else {",
									"    pm.response.to.have.status(400);",
									"  }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
